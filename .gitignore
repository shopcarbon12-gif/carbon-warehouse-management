# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build

# local tooling (e.g. Flutter SDK clone for scripts)
/.tools/

# Flutter (carbon_wms)
/mobile/carbon_wms/build/
/mobile/carbon_wms/.dart_tool/
/mobile/carbon_wms/.flutter-plugins-dependencies
/mobile/carbon_wms/android/.kotlin/

# misc
.DS_Store
*.pem
# Local export of Cursor parent-chat transcripts (may contain secrets)
/combined-cursor-agent-transcripts.txt
/combined-cursor-conversations-user-cursor.txt
/project-dev-prompts-chronological.txt
.playwright-mcp/
_ls*.txt

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local OTA APK uploads
public/uploads/mobile-apk/

# Theme evidence PNGs (regenerate with npm run evidence:theme:*); embedded report is committed
docs/light-theme-evidence/before/*.png
docs/light-theme-evidence/after/*.png
docs/light-theme-evidence/changed-pages-button-theme/*.png
