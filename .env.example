# =============================================================================
# Local dev ↔ Production (https://wms.shopcarbon.com)
# =============================================================================
# Use the **same variable names** locally and on Coolify; only values differ.
#
# `npm run dev` auto-fills public URLs when unset (see scripts/run-next-dev.mjs):
#   WMS_APP_PUBLIC_BASE_URL=http://localhost:3040
#   NEXT_PUBLIC_BASE_URL=http://localhost:3040
#
# Production (Coolify): set both to https://wms.shopcarbon.com (no trailing slash).
# Optional: copy Coolify env into gitignored `.env.coolify.local` for scripts/agents.
# To mirror **live data** on your PC: pg_dump from Coolify Postgres → restore locally
# (see README); DATABASE_URL below stays localhost — do not commit production secrets.
#
# Lightspeed OAuth: register redirect URL(s) to match LS_REDIRECT_URI / public base, e.g.
#   http://localhost:3040/api/lightspeed/callback
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (Coolify)
# -----------------------------------------------------------------------------
# In Coolify: create a PostgreSQL resource, then link it to this application.
# Copy the internal connection URL from the database resource (or use the
# variables Coolify injects) and set DATABASE_URL here for production.
#
# Internal hostname is usually the Postgres service name on Coolify’s Docker
# network, e.g. postgresql://USER:PASSWORD@postgres-xxxxxxxx:5432/DATABASE
#
# For local dev, use localhost or a Docker Compose Postgres service.
#
# Optional (gitignored): copy production vars from Coolify into .env.coolify.local
# so the agent can run migrate/seed against your DB without pasting secrets in chat.
# Use only this app’s linked PostgreSQL URL from the CARBON WMS Coolify project
# (do not reuse another app’s Postgres on the same Coolify server).
#
# Docker / Coolify (optional): first-boot schema + sample data without a laptop:
#   WMS_AUTO_MIGRATE=1  — run scripts/schema.sql if users table is missing
#   WMS_AUTO_SEED=1     — run scripts/seed-bootstrap.sql (admin@example.com /
#                         ChangeMeOnFirstLogin!1 — change password after login)
# Remove or set to 0 after the database is initialized.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/carbon_wms
# Localhost URL = sample/demo tenants & SKUs from seed — NOT your live Coolify data.
# To mirror production on your PC: use pg_dump from Coolify Postgres → restore locally,
# or set DATABASE_URL to the server DB (internal hostnames usually need an SSH tunnel).
# Hide the amber “local/demo data” banner: WMS_HIDE_LOCAL_DB_BANNER=1
# Real local dev (mirrored DB + prod integration keys, no demo LS catalog): see npm run env:parity-local
# WMS_PRODUCTION_PARITY_LOCAL=1   # set by env:parity-local — hides demo banner with mirrored DB
# WMS_LS_STRICT=1                  # never silently ingest/compare demo Lightspeed SKUs; fail if API unavailable
# WMS_AUTO_MIGRATE=0
# WMS_AUTO_SEED=0

# Local seed only (scripts/seed.ts). Omit in production or set a strong secret.
# SEED_ADMIN_PASSWORD=your-secure-password

# -----------------------------------------------------------------------------
# Session / auth (set in Coolify “Environment variables” for production)
# -----------------------------------------------------------------------------
# SESSION_SECRET=generate-a-long-random-string
# Optional: force session cookie Secure flag in production (default: on only when X-Forwarded-Proto=https)
# WMS_SESSION_COOKIE_SECURE=0

# Handheld POST /api/handheld/batches (header X-WMS-Device-Key)
# WMS_DEVICE_KEY=long-random-string
#
# Edge POST /api/edge/ingest — header `x-edge-api-key` (see lib/auth/edge-auth.ts)
# EDGE_API_KEY=long-random-string
# Legacy aliases still accepted: WMS_EDGE_INGEST_KEY, WMS_DEVICE_KEY, X-WMS-Edge-Key, etc.
# WMS_EDGE_INGEST_KEY=long-random-string

# -----------------------------------------------------------------------------
# RFID Printer Configuration (Requires Tailscale/VPN for cloud Coolify)
# -----------------------------------------------------------------------------
PRINTER_HOST=192.168.1.3
PRINTER_PORT=80
PRINTER_URI=PSTPRNT
WMS_COMPANY_PREFIX=1044991

# -----------------------------------------------------------------------------
# Production / Coolify (set in dashboard; mirror in gitignored .env.coolify.local)
# -----------------------------------------------------------------------------
# NODE_ENV=production
# Public origin of the WMS (no trailing slash). OAuth redirects must match provider apps exactly.
# Same resolution order as carbon-gen for Lightspeed: NEXT_PUBLIC_BASE_URL first, then WMS_APP_PUBLIC_BASE_URL.
# NEXT_PUBLIC_BASE_URL=https://wms.shopcarbon.com
# WMS_APP_PUBLIC_BASE_URL=https://wms.shopcarbon.com

# Cloudflare R2 (if used)
# R2_ACCOUNT_ID=
# R2_BUCKET=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Email (if used)
# RESEND_API_KEY=
# PUSH_NOTIFICATION_EMAIL=

# Lightspeed — R-Series is the primary path (OAuth + account id, NOT the X shop subdomain flow).
# API host defaults to https://api.lightspeedapp.com (override with LS_API_BASE).
#
# Required for live R-Series catalog / sales reads:
#   LS_CLIENT_ID, LS_CLIENT_SECRET, LS_REFRESH_TOKEN, LS_ACCOUNT_ID
# Optional:
#   LS_API_BASE (default https://api.lightspeedapp.com)
#   LS_REDIRECT_URI (default {WMS_APP_PUBLIC_BASE_URL}/api/lightspeed/callback — must match Lightspeed app)
#   LS_OAUTH_TOKEN_URL (default tries merchantos + legacy endpoints; use <<domain_prefix>> only if you customize)
#   LS_DOMAIN_PREFIX — optional for R-Series (e.g. us); adds retail token URL as an extra refresh candidate
#   LS_MAX_CATALOG_PAGES=80   # V3 pagination cap
# LS_CLIENT_ID=
# LS_CLIENT_SECRET=
# LS_REFRESH_TOKEN=
# LS_ACCOUNT_ID=
# LS_API_BASE=https://api.lightspeedapp.com
# LS_REDIRECT_URI=
# LS_OAUTH_TOKEN_URL=
# LS_DOMAIN_PREFIX=
# LS_MAX_CATALOG_PAGES=80
#
# Retail X-Series (optional fallback only, after R-Series): LS_DOMAIN_PREFIX = shop subdomain +
# LS_PERSONAL_TOKEN or OAuth to *.retail.lightspeed.app
# LS_PERSONAL_TOKEN=
#
# WMS → Lightspeed inventory transfer (R-Series V3), scope employee:transfers:
#   1) POST /api/integrations/lightspeed/sync-slip-transfer
#      { "slipNumber", "sendingShopID", "receivingShopID", "note"?,
#        "transferItems"? [ { "itemID", "toSend" } ], "send"? boolean }
#   2) Or after (1) without items/send: POST .../slip-transfer-add-items { slipNumber, items }
#   3) Then POST .../slip-transfer-send { slipNumber }
# itemID = Lightspeed Retail Item ID (not WMS internal ids).

# Optional: trigger deploy via API (npm run deploy:coolify). Copy URL from Coolify → WMS app → Webhooks.
# COOLIFY_DEPLOY_WEBHOOK_URL=http://YOUR_COOLIFY_HOST:8000/api/v1/deploy?uuid=YOUR_APP_UUID&force=false
# Bearer token from Coolify → Keys & Tokens → API Tokens — **deploy** permission is enough for webhook only.
# COOLIFY_API_TOKEN=
#
# Optional: push Lightspeed + WMS_APP_PUBLIC_BASE_URL from .env.coolify.local to Coolify (needs write-capable API token):
#   npm run coolify:set-lightspeed && npm run deploy:coolify
#
# Optional: verify API read access: npm run coolify:api-check (GET /applications/{uuid}).
# Optional: set DATABASE_URL via API (npm run coolify:set-db). Needs a token that can **update** envs
# (full * / write — not deploy-only; see Coolify → API authorization docs). Value = Postgres URL (internal).
# COOLIFY_DATABASE_URL=postgresql://postgres:PASSWORD@postgresql-database-xxxxx:5432/postgres
# COOLIFY_BASE_URL=http://YOUR_COOLIFY_HOST:8000/api/v1
# COOLIFY_APP_UUID=your-wms-app-uuid

# -----------------------------------------------------------------------------
# Optional: CLI upload of handheld APK (admin session cookie from browser devtools)
# -----------------------------------------------------------------------------
# WMS_APP_PUBLIC_BASE_URL=https://wms.example.com
# WMS_UPLOAD_SESSION_COOKIE=wms_session=...   # full cookie value; admin scope required (short-lived — paste after browser login)
# Same keys may live in gitignored `.env.coolify.local`; `scripts/upload-mobile-apk.mjs` reads them automatically.
# npm run upload:mobile-apk -- path/to/app-release.apk 0.1.10+14
# Or: APK_PATH=... APK_VERSION_LABEL=... npm run upload:mobile-apk

# -----------------------------------------------------------------------------
# Optional: subpath deploy (must match build-time env — see next.config.ts)
# -----------------------------------------------------------------------------
# WMS_BASE_PATH=/wms
