{
  "version": "0.2.0",
  // cwd must live on a path WITHOUT spaces: objective_c native-asset hooks invoke .cmd
  // that splits on spaces ("D:\Projects\My" …). Use junction D:\cwm → repo root:
  //   mklink /J D:\cwm "D:\Projects\My project\carbon-warehouse-management"
  // Windows (desktop) needs Visual Studio "Desktop development with C++". Otherwise pick
  // Chrome or Android in the device selector, or use the "Chrome web" launch config.
  "configurations": [
    {
      "name": "carbon_wms",
      "cwd": "D:/cwm/mobile/carbon_wms",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart"
    },
    {
      "name": "carbon_wms (Chrome web · localhost:50122)",
      "cwd": "D:/cwm/mobile/carbon_wms",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "chrome",
      "flutterRunAdditionalArgs": ["--web-port=50122"]
    },
    {
      "name": "carbon_wms (profile mode)",
      "cwd": "D:/cwm/mobile/carbon_wms",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "profile"
    },
    {
      "name": "carbon_wms (release mode)",
      "cwd": "D:/cwm/mobile/carbon_wms",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "release"
    },
    {
      "name": "carbon_wms (Chrome web profile · localhost:50122)",
      "cwd": "D:/cwm/mobile/carbon_wms",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "chrome",
      "flutterMode": "profile",
      "flutterRunAdditionalArgs": ["--web-port=50122"]
    },
    {
      "name": "carbon_chainway_driver",
      "cwd": "D:/cwm/mobile/carbon_wms/packages/carbon_chainway_driver",
      "request": "launch",
      "type": "dart"
    },
    {
      "name": "carbon_chainway_driver (profile mode)",
      "cwd": "D:/cwm/mobile/carbon_wms/packages/carbon_chainway_driver",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "carbon_chainway_driver (release mode)",
      "cwd": "D:/cwm/mobile/carbon_wms/packages/carbon_chainway_driver",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    },
    {
      "name": "carbon_zebra_driver",
      "cwd": "D:/cwm/mobile/carbon_wms/packages/carbon_zebra_driver",
      "request": "launch",
      "type": "dart"
    },
    {
      "name": "carbon_zebra_driver (profile mode)",
      "cwd": "D:/cwm/mobile/carbon_wms/packages/carbon_zebra_driver",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "carbon_zebra_driver (release mode)",
      "cwd": "D:/cwm/mobile/carbon_wms/packages/carbon_zebra_driver",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    }
  ]
}
