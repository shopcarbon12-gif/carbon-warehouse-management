{
  "name": "carbon-warehouse-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3040",
    "build": "npm run db:migrate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose up -d",
    "db:ensure": "node scripts/ensure-database.mjs",
    "db:migrate": "npx tsx scripts/migrate-incremental.ts",
    "db:migrate:incremental": "npx tsx scripts/migrate-rfid-only.ts",
    "db:seed": "npx tsx scripts/seed.ts",
    "migrate": "npm run db:migrate",
    "migrate:incremental": "npm run db:migrate:incremental",
    "seed": "npm run db:seed",
    "db:setup": "npm run db:ensure && npm run db:migrate && npm run db:seed",
    "worker": "npx tsx scripts/worker.ts",
    "test:e2e": "playwright test",
    "deploy:coolify": "node scripts/trigger-coolify-deploy.mjs",
    "epc:validate": "npx tsx scripts/validate-epc-encoding.ts",
    "printer:test": "npx tsx scripts/test-printer-connection.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "pg": "^8.16.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swr": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
