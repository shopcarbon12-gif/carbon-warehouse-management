{
  "name": "carbon-warehouse-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next-dev.mjs",
    "dev:turbo": "node scripts/run-next-dev.mjs --turbo",
    "clean:next": "node scripts/clean-next-cache.mjs",
    "build": "npm run db:migrate && node ./node_modules/next/dist/bin/next build --webpack",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "db:up": "docker compose up -d",
    "db:ensure": "node scripts/ensure-database.mjs",
    "db:migrate": "npx tsx scripts/migrate-incremental.ts",
    "db:migrate:incremental": "npx tsx scripts/migrate-rfid-only.ts",
    "db:seed": "npx tsx scripts/seed.ts",
    "migrate": "npm run db:migrate",
    "migrate:incremental": "npm run db:migrate:incremental",
    "seed": "npm run db:seed",
    "db:setup": "npm run db:ensure && npm run db:migrate && npm run db:seed",
    "db:mirror:ssh": "node scripts/db-mirror-ssh-dump-restore.mjs",
    "worker": "npx tsx scripts/worker.ts",
    "test:e2e": "playwright test",
    "evidence:theme:before": "node scripts/capture-theme-evidence.mjs before",
    "evidence:theme:after": "node scripts/capture-theme-evidence.mjs after",
    "evidence:theme:report": "node scripts/generate-light-theme-report.mjs",
    "evidence:button-theme-pages": "node scripts/capture-button-theme-pages.mjs",
    "deploy:coolify": "node scripts/trigger-coolify-deploy.mjs",
    "deploy:coolify:watch": "node scripts/deploy-coolify-watch.mjs",
    "coolify:poll-deployment": "node scripts/poll-coolify-deployment.mjs",
    "coolify:set-db": "node scripts/coolify-set-database-url.mjs",
    "coolify:set-lightspeed": "node scripts/coolify-set-lightspeed-env.mjs",
    "coolify:sync-postgres-url": "node scripts/coolify-sync-postgres-url.mjs",
    "coolify:fetch-database-url-local": "node scripts/coolify-fetch-database-url-to-local.mjs",
    "coolify:api-check": "node scripts/coolify-api-check.mjs",
    "coolify:ensure-uploads-volume": "node scripts/coolify-ensure-uploads-volume.mjs",
    "coolify:list-env-keys": "node scripts/coolify-list-env-keys.mjs",
    "coolify:patch-env": "node scripts/coolify-patch-env-bulk.mjs",
    "diagnose:db": "node scripts/diagnose-wms-db.mjs",
    "db:copy-bins": "node scripts/copy-bins-to-target.mjs",
    "db:copy-bins:tunnel": "node scripts/copy-bins-through-tunnel.mjs",
    "db:ensure-orlando-bins": "node scripts/ensure-orlando-seed-bins.mjs",
    "db:ensure-orlando-bins:coolify": "node scripts/ensure-orlando-seed-bins.mjs --coolify",
    "db:ensure-orlando-bins:coolify:tunnel": "node scripts/ensure-orlando-bins-through-tunnel.mjs",
    "coolify:set-public-urls": "node scripts/coolify-set-public-urls.mjs",
    "env:ensure-local": "node scripts/ensure-local-public-env.mjs",
    "env:parity-local": "node scripts/ensure-production-parity-local.mjs",
    "sync:public-urls": "npm run env:ensure-local && npm run coolify:set-public-urls && npm run deploy:coolify",
    "epc:validate": "npx tsx scripts/validate-epc-encoding.ts",
    "printer:test": "npx tsx scripts/test-printer-connection.ts",
    "upload:mobile-apk": "node scripts/upload-mobile-apk.mjs",
    "favicon:build": "node scripts/build-app-icons.mjs"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.13",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "pg": "^8.16.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swr": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "png-to-ico": "^2.1.8"
  }
}
